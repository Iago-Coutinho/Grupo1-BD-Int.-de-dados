    as
  
  (
    

with src as (
    select * from "postgres"."dw_elt_staging"."stg_itbi_raw"
),

dim_t as (select * from "postgres"."dw_elt_dw_elt"."dim_tempo"),
dim_l as (select * from "postgres"."dw_elt_dw_elt"."dim_localizacao")

select
    dim_t.data_completa                                    as sk_tempo_ref,
    dim_l.cod_logradouro                                   as sk_localizacao_ref,
    src.tipo_imovel,
    src.tipo_construcao,
    src.padrao_acabamento,
    src.estado_conservacao,
    src.tipo_ocupacao,
    src.valor_avaliacao,
    src.area_terreno,
    src.area_construida,
    src.fracao_ideal,
    src.sfh,
    case
        when src.area_construida > 0
        then round(src.valor_avaliacao / src.area_construida, 2)
        else null
    end                                                    as valor_m2_construido,
    extract(year from src.data_transacao)::integer
        - src.ano_construcao_int                           as idade_imovel_anos
from src
join dim_t on dim_t.data_completa = src.data_transacao
join dim_l on dim_l.cod_logradouro = src.cod_logradouro
          and dim_l.numero         = src.numero_tratado
  );
  
