  (
    

with src as (
    select * from "postgres"."staging"."stg_itbi_raw"
),

dim_t as (select * from "postgres"."dw_elt"."dim_tempo"),
dim_l as (select * from "postgres"."dw_elt"."dim_localizacao"),
dim_c as (select * from "postgres"."dw_elt"."dim_caracteristica")

select
    row_number() over ()::integer                          as sk_transacao,
    dim_t.sk_tempo,
