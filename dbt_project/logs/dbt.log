  create  table "postgres"."dw_elt_dw_elt"."fato_transacao_itbi__dbt_tmp"
  
  
    as
  
  (
    with src as (
    select * from "postgres"."dw_elt_staging"."stg_itbi_raw"
),

dim_t as (select * from "postgres"."dw_elt_dw_elt"."dim_tempo"),
dim_l as (select * from "postgres"."dw_elt_dw_elt"."dim_localizacao"),
dim_i as (select * from "postgres"."dw_elt_dw_elt"."dim_imovel"),
dim_c as (select * from "postgres"."dw_elt_dw_elt"."dim_caracteristica")

select
    t.data_completa                                        as sk_tempo_ref,
    l.cod_logradouro                                       as sk_localizacao_ref,
    src.valor_avaliacao,
    src.area_terreno,
    src.area_construida,
    src.fracao_ideal,
    src.sfh,
    case
        when src.area_construida > 0
        then round(src.valor_avaliacao / src.area_construida, 2)
        else null
    end                                                    as valor_m2_construido,
    extract(year from src.data_transacao)::integer
        - src.ano_construcao_int                           as idade_imovel_anos
from src
join dim_t on dim_t.data_completa = src.data_transacao
join dim_l on dim_l.cod_logradouro = src.cod_logradouro
          and dim_l.numero         = src.numero_tratado
join dim_i on (dim_i.complemento_numero is not distinct from src.complemento_numero)
          and (dim_i.nome_edificio       is not distinct from src.nome_edificio)
          and (dim_i.ano_construcao      is not distinct from src.ano_construcao_int)
join dim_c on dim_c.tipo_imovel         = src.tipo_imovel
